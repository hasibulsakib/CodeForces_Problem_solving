#include<bits/stdc++.h>
using namespace std;
int main(){
    int t;
    cin >> t;
    while(t--){
        int n=7;
        int add=0;
        int ass=0;
        vector<int>v(n);
        for(int i=0;i<n;i++){
            cin >> v[i];
        }
        sort(v.begin(),v.end());
 
        for(int i=0;i<n-1;i++){
            v[i]=-1*v[i];
             ass+=v[i];
             add=ass+v[n-1];
        }
        
        cout << add << endl;
    }
}